# =============================================================================
# WireGuard VPN — Server Environment Configuration
# =============================================================================
# This file is GENERATED by install.sh and sourced by all management scripts.
# Do NOT edit manually unless you know what you are doing.
# Permissions should be 600 (root read/write only).
# =============================================================================

# WireGuard interface name
WG_INTERFACE="wg0"

# UDP port WireGuard listens on
WG_PORT="51820"

# VPN subnet (CIDR)
WG_SUBNET="10.100.0.0/24"

# Server's IP inside the VPN tunnel
WG_SERVER_IP="10.100.0.1"

# DNS servers pushed to clients
WG_DNS="1.1.1.1,8.8.8.8"

# Maximum Transmission Unit — 1420 avoids fragmentation over most networks
WG_MTU="1420"

# How often clients send keepalive packets (seconds) — prevents NAT timeout
WG_KEEPALIVE="25"

# Server's public-facing network interface (e.g. eth0, ens3, enp0s3)
# This is auto-detected by install.sh
SERVER_IFACE="eth0"

# Path to WireGuard config directory
WG_CONFIG_DIR="/etc/wireguard"

# Path to client configs directory
CLIENT_CONFIG_DIR="/etc/wireguard/clients"

# Path to the IP address counter file (tracks next available client IP)
IP_COUNTER_FILE="/etc/wireguard/.ip_counter"

# Path to the client registry (name -> IP mapping)
CLIENT_REGISTRY="/etc/wireguard/.client_registry"
